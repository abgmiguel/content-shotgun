{
  "$schema": "https://schema.tauri.app/config/1",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devPath": "http://localhost:5173",
    "distDir": "../dist"
  },
  "package": {
    "productName": "Local AI Draft Workspace",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "fs": {
        "all": true,
        "scope": ["**"]
      },
      "path": {
        "all": true
      },
      "dialog": {
        "all": true
      }
    },
    "bundle": {
      "active": false,
      "identifier": "com.miguel.localaidraftworkspace"
    },
    "windows": [
      {
        "title": "Local AI Draft Workspace",
        "width": 1600,
        "height": 950,
        "resizable": true
      }
    ]
  }
}
